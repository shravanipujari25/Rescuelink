# =============================================================================
# GEOGUARD FRONTEND — React + Vite .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# -----------------------------------------------------------------------------
# Environment Variables — NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
playwright-report/
test-results/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Editor Directories & Files
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
